{
    "layer": "top",
    "position": "top",
    "height": 32,
    "spacing": 4,

    "modules-left": ["custom/launcher", "hyprland/workspaces"],
    "modules-center": [],
    "modules-right": ["network", "pulseaudio", "clock", "battery", "custom/power"],

    "custom/launcher": {
        "format": "🕷",
        "on-click": "wofi --show drun",
        "tooltip": false
    },

    "hyprland/workspaces": {
        "format": "{icon}",
        "on-click": "activate",
        "all-outputs": true,
        "format-icons": {
            "active": "●",
            "default": "●",
            "empty": "●"
        },
        "persistent-workspaces": {
            "*": 5
        }
    },

    "network": {
        "format-wifi": "📶 {signalStrength}%",
        "format-ethernet": "🌐 Connected",
        "format-disconnected": "⚠ Disconnected",
        "tooltip-format": "{essid} ({signalStrength}%)",
        "on-click": "nm-connection-editor"
    },

    "pulseaudio": {
        "format": "🔊 {volume}%",
        "format-muted": "🔇 Muted",
        "on-click": "pavucontrol"
    },

    "clock": {
        "format": "🕐 {:%H:%M}",
        "tooltip-format": "{:%A, %d %B %Y}"
    },

    "battery": {
        "format": "{icon} {capacity}%",
        "format-icons": ["", "", "", "", ""],
        "format-charging": " {capacity}%",
        "states": {
            "warning": 30,
            "critical": 15
        }
    },

    "custom/power": {
        "format": "⏻",
        "on-click": "wlogout",
        "tooltip": false
    }
}
